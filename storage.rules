rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Session videos — only the uploader (matched by sessionId prefix) can write
    match /sessions/{sessionId}/{fileName} {
      allow read:  if true;          // public read for demo playback
      allow write: if request.auth != null
                   && request.resource.size < 500 * 1024 * 1024  // 500 MB max
                   && request.resource.contentType.matches('video/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
