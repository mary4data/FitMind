# ── Google Cloud / Firebase ───────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=fitmind-490222
# For local dev, authenticate with: gcloud auth application-default login
# No key file needed — ADC picks up your gcloud credentials automatically.
# On Cloud Run the attached service account is used automatically.

# ── Vertex AI ────────────────────────────────────────────────────────────────
# No API key needed — authenticated via ADC (gcloud auth application-default login)
VERTEX_LOCATION=us-central1

# ── Cloud Storage ─────────────────────────────────────────────────────────────
GCS_BUCKET=fitmind-490222.appspot.com
GCS_REGION=us-central1

# ── Backend server ────────────────────────────────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ── Frontend (Next.js public vars) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# Firebase client config — copy from Firebase Console → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=fitmind-490222.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=fitmind-490222
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=fitmind-490222.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
